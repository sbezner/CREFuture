---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About CREFuture" description="Understanding our mission to bridge technology and commercial real estate.">
  <!-- Hero Section -->
  <section class="py-20 px-6">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-5xl font-bold mb-6 gradient-text">
        About CREFuture
      </h1>
      <p class="text-xl text-gray-300">
        A global digital platform dedicated to exploring the transformative collision of Artificial Intelligence and Commercial Real Estate.
      </p>
    </div>
  </section>

  <!-- Mission Section -->
  <section class="py-16 px-6 border-t border-primary/20">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-primary">
        Our Mission
      </h2>
      <p class="text-lg text-gray-300 mb-6">
        CREFuture serves as a visionary headquarters for understanding how the commercial real estate industry's fundamental "operating system" is being rewritten by artificial intelligence.
      </p>
      <p class="text-lg text-gray-300 mb-6">
        Rather than focusing on specific geographic markets or datasets, we provide a comprehensive exploration of how AI is transforming every aspect of the industry—from workforce dynamics to operational processes to technology infrastructure.
      </p>
      <p class="text-lg text-gray-300">
        Our ultimate goal is to act as a bridge between the traditional world of "silicon and brick," providing a roadmap for the next decade of global property investment and management.
      </p>
    </div>
  </section>

  <!-- Philosophy Section -->
  <section class="py-16 px-6 border-t border-secondary/20">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-secondary">
        Tech Optimism Philosophy
      </h2>
      <p class="text-lg text-gray-300 mb-6">
        We reject the narrative of total human replacement by AI. Instead, we champion the era of the <strong>Augmented Professional</strong>.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8">
        <div class="p-6 rounded-lg bg-primary/5 border border-primary/20">
          <h3 class="text-xl font-bold text-primary mb-3">AI Handles Drudgery</h3>
          <p class="text-gray-400">
            High-volume, repetitive tasks that consume professional time are automated, freeing humans for strategic work.
          </p>
        </div>
        <div class="p-6 rounded-lg bg-secondary/5 border border-secondary/20">
          <h3 class="text-xl font-bold text-secondary mb-3">Humans Drive Strategy</h3>
          <p class="text-gray-400">
            Professionals focus on relationship building, creative deal-making, and high-level strategic decisions.
          </p>
        </div>
        <div class="p-6 rounded-lg bg-accent/5 border border-accent/20">
          <h3 class="text-xl font-bold text-accent mb-3">Confidence & Growth</h3>
          <p class="text-gray-400">
            Leaders gain confidence in their AI tools, driving industry innovation and professional growth.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Three Pillars Section -->
  <section class="py-16 px-6 border-t border-accent/20">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">
        Our Three Core Pillars
      </h2>
      <div class="space-y-8">
        <div class="border-l-4 border-primary pl-8">
          <h3 class="text-2xl font-bold text-primary mb-3">The Future of the Workforce</h3>
          <p class="text-gray-400 mb-3">
            Deep dives into how specific roles—from brokers to asset managers—are evolving with AI integration. We explore the new skill sets required to thrive in an AI-integrated market.
          </p>
          <a href="/CREFuture/workforce/" class="text-primary hover:text-transparent hover:bg-clip-text hover:bg-gradient-to-r hover:from-primary hover:to-secondary transition">Explore Workforce →</a>
        </div>
        <div class="border-l-4 border-secondary pl-8">
          <h3 class="text-2xl font-bold text-secondary mb-3">Functional Transformation</h3>
          <p class="text-gray-400 mb-3">
            Exploration of how AI changes the "how-to" of the industry. This includes autonomous building operations, predictive leasing, and hyper-accurate, real-time valuations.
          </p>
          <a href="/CREFuture/transformation/" class="text-secondary hover:text-transparent hover:bg-clip-text hover:bg-gradient-to-r hover:from-primary hover:to-secondary transition">Explore Transformation →</a>
        </div>
        <div class="border-l-4 border-accent pl-8">
          <h3 class="text-2xl font-bold text-accent mb-3">The Global Tech Stack</h3>
          <p class="text-gray-400 mb-3">
            A curated, high-level look at the specific technologies and AI agents that are moving from experimental "hype" to essential industry standards.
          </p>
          <a href="/CREFuture/tech-stack/" class="text-accent hover:text-transparent hover:bg-clip-text hover:bg-gradient-to-r hover:from-primary hover:to-secondary transition">Explore Tech Stack →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto text-center border-t border-primary/20 pt-12">
      <h2 class="text-3xl font-bold mb-6">
        Ready to Explore the Future?
      </h2>
      <p class="text-gray-300 mb-8">
        Dive into any of our three pillars to understand how AI is reshaping commercial real estate.
      </p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a href="/CREFuture/workforce/" class="btn btn-primary">Workforce</a>
        <a href="/CREFuture/transformation/" class="btn btn-secondary">Transformation</a>
        <a href="/CREFuture/tech-stack/" class="btn btn-outline">Tech Stack</a>
      </div>
    </div>
  </section>

  <!-- Navigation -->
  <section class="py-12 px-6 border-t border-primary/20">
    <div class="max-w-4xl mx-auto">
      <a href="/CREFuture/" class="text-gray-400 hover:text-primary transition">← Back Home</a>
    </div>
  </section>
</Layout>
