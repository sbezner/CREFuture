---
import Layout from '../layouts/Layout.astro';
---

<Layout title="The Global Tech Stack" description="Curated technologies and AI agents transforming commercial real estate.">
  <!-- Hero Section -->
  <section class="py-20 px-6 bg-gradient-to-b from-accent/10 to-dark">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-5xl font-bold mb-6 text-accent">
        The Global Tech Stack
      </h1>
      <p class="text-xl text-gray-300 mb-8">
        A curated exploration of the technologies and AI agents that are moving from experimental hype to essential industry standards in commercial real estate.
      </p>
    </div>
  </section>

  <!-- Content Sections -->
  <section class="py-16 px-6 max-w-4xl mx-auto">
    <!-- Placeholder for content -->
    <div class="space-y-12">
      <div class="border-l-4 border-primary pl-8">
        <h2 class="text-3xl font-bold mb-4 gradient-text">
          Core AI Technologies
        </h2>
        <p class="text-gray-400 mb-4">
          Content coming soon. We're curating information on the foundational AI technologies transforming real estate.
        </p>
      </div>

      <div class="border-l-4 border-secondary pl-8">
        <h2 class="text-3xl font-bold mb-4 gradient-text">
          Enterprise AI Agents
        </h2>
        <p class="text-gray-400 mb-4">
          Explore the intelligent agents that are automating key real estate processes and workflows.
        </p>
      </div>

      <div class="border-l-4 border-accent pl-8">
        <h2 class="text-3xl font-bold mb-4 gradient-text">
          Data & Analytics Infrastructure
        </h2>
        <p class="text-gray-400 mb-4">
          Discover the data platforms and analytics tools enabling predictive insights in real estate.
        </p>
      </div>
    </div>

    <div class="mt-16 p-8 rounded-lg bg-accent/5 border border-accent/20">
      <h3 class="text-2xl font-bold mb-4">Technology Categories</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="space-y-3">
          <h4 class="font-semibold text-accent">AI & Machine Learning</h4>
          <ul class="space-y-2 text-gray-400">
            <li class="flex gap-2"><span class="text-primary">•</span> <span>Large Language Models</span></li>
            <li class="flex gap-2"><span class="text-primary">•</span> <span>Computer Vision Systems</span></li>
            <li class="flex gap-2"><span class="text-primary">•</span> <span>Predictive Analytics</span></li>
          </ul>
        </div>
        <div class="space-y-3">
          <h4 class="font-semibold text-secondary">Infrastructure</h4>
          <ul class="space-y-2 text-gray-400">
            <li class="flex gap-2"><span class="text-secondary">•</span> <span>Cloud Platforms</span></li>
            <li class="flex gap-2"><span class="text-secondary">•</span> <span>Data Warehouses</span></li>
            <li class="flex gap-2"><span class="text-secondary">•</span> <span>API Ecosystems</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Navigation -->
  <section class="py-12 px-6 border-t border-accent/20">
    <div class="max-w-4xl mx-auto flex justify-between">
      <a href="/CREFuture/transformation/" class="text-gray-400 hover:text-accent transition">← Transformation</a>
      <a href="/CREFuture/about/" class="text-gray-400 hover:text-accent transition">About →</a>
    </div>
  </section>
</Layout>
