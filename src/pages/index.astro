---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <!-- Hero Section -->
  <section class="py-32 px-6 max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h1 class="text-6xl font-bold mb-6 gradient-text">
        The Future of Real Estate is Here
      </h1>
      <p class="text-xl text-gray-300 max-w-2xl mx-auto mb-8">
        CREFuture is a global digital platform exploring the transformative collision of Artificial Intelligence and Commercial Real Estate. We champion the Augmented Professional—where AI handles the drudgery, humans drive strategy.
      </p>
      <a href="/CREFuture/about/" class="btn btn-primary inline-block">
        Explore Our Vision
      </a>
    </div>
  </section>

  <!-- Three Pillars -->
  <section class="py-20 px-6 bg-gradient-to-b from-dark via-dark to-dark/50">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-4xl font-bold text-center mb-16 gradient-text">
        Three Pillars of Transformation
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Pillar 1 -->
        <a href="/CREFuture/workforce/" class="group">
          <div class="p-8 rounded-lg border border-primary/20 hover:border-primary/50 hover:bg-primary/5 transition-all duration-300 h-full">
            <div class="text-4xl mb-4 group-hover:scale-110 transition-transform">🤖</div>
            <h3 class="text-2xl font-bold mb-3 text-primary group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-primary group-hover:to-secondary transition">
              The Future of Workforce
            </h3>
            <p class="text-gray-400 group-hover:text-gray-300 transition">
              Discover how specific real estate roles—from brokers to asset managers—are evolving with AI integration. Explore the new skill sets required to thrive.
            </p>
          </div>
        </a>

        <!-- Pillar 2 -->
        <a href="/CREFuture/transformation/" class="group">
          <div class="p-8 rounded-lg border border-secondary/20 hover:border-secondary/50 hover:bg-secondary/5 transition-all duration-300 h-full">
            <div class="text-4xl mb-4 group-hover:scale-110 transition-transform">⚙️</div>
            <h3 class="text-2xl font-bold mb-3 text-secondary group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-primary group-hover:to-secondary transition">
              Functional Transformation
            </h3>
            <p class="text-gray-400 group-hover:text-gray-300 transition">
              Explore how AI is rewriting the industry's operating system—autonomous operations, predictive leasing, and hyper-accurate valuations.
            </p>
          </div>
        </a>

        <!-- Pillar 3 -->
        <a href="/CREFuture/tech-stack/" class="group">
          <div class="p-8 rounded-lg border border-accent/20 hover:border-accent/50 hover:bg-accent/5 transition-all duration-300 h-full">
            <div class="text-4xl mb-4 group-hover:scale-110 transition-transform">🛠️</div>
            <h3 class="text-2xl font-bold mb-3 text-accent group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-primary group-hover:to-secondary transition">
              The Global Tech Stack
            </h3>
            <p class="text-gray-400 group-hover:text-gray-300 transition">
              A curated look at the technologies and AI agents moving from experimental hype to essential industry standards.
            </p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-6 max-w-6xl mx-auto">
    <div class="text-center">
      <h2 class="text-3xl font-bold mb-6">
        Building the Bridge Between Silicon and Brick
      </h2>
      <p class="text-gray-400 mb-8 max-w-2xl mx-auto">
        Join us in exploring the roadmap for the next decade of global property investment and management. Understand how the Augmented Professional will shape the future of commercial real estate.
      </p>
      <div class="flex gap-4 justify-center">
        <a href="/CREFuture/workforce/" class="btn btn-primary">Start with Workforce</a>
        <a href="/CREFuture/tech-stack/" class="btn btn-outline">Explore Tech Stack</a>
      </div>
    </div>
  </section>
</Layout>
