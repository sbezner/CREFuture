---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Functional Transformation" description="Explore how AI is transforming the core operations of commercial real estate.">
  <!-- Hero Section -->
  <section class="py-20 px-6 bg-gradient-to-b from-secondary/10 to-dark">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-5xl font-bold mb-6 text-secondary">
        Functional Transformation
      </h1>
      <p class="text-xl text-gray-300 mb-8">
        AI is rewriting the operating system of commercial real estate. From autonomous building operations to predictive leasing and real-time valuations, discover how core processes are evolving.
      </p>
    </div>
  </section>

  <!-- Content Sections -->
  <section class="py-16 px-6 max-w-4xl mx-auto">
    <!-- Placeholder for content -->
    <div class="space-y-12">
      <div class="border-l-4 border-secondary pl-8">
        <h2 class="text-3xl font-bold mb-4 gradient-text">
          Autonomous Building Operations
        </h2>
        <p class="text-gray-400 mb-4">
          Content coming soon. We're exploring how AI enables fully autonomous, intelligent building management systems.
        </p>
      </div>

      <div class="border-l-4 border-primary pl-8">
        <h2 class="text-3xl font-bold mb-4 gradient-text">
          Predictive Leasing & Tenant Intelligence
        </h2>
        <p class="text-gray-400 mb-4">
          Learn how AI transforms tenant acquisition, retention, and management through predictive intelligence.
        </p>
      </div>

      <div class="border-l-4 border-accent pl-8">
        <h2 class="text-3xl font-bold mb-4 gradient-text">
          Hyper-Accurate, Real-Time Valuations
        </h2>
        <p class="text-gray-400 mb-4">
          Discover how AI-driven valuation models provide unprecedented accuracy and real-time market insights.
        </p>
      </div>
    </div>

    <div class="mt-16 p-8 rounded-lg bg-secondary/5 border border-secondary/20">
      <h3 class="text-2xl font-bold mb-4">Key Transformations</h3>
      <ul class="space-y-3 text-gray-400">
        <li class="flex gap-3">
          <span class="text-secondary">→</span>
          <span>HVAC and energy optimization through AI</span>
        </li>
        <li class="flex gap-3">
          <span class="text-secondary">→</span>
          <span>Tenant behavior prediction and demand forecasting</span>
        </li>
        <li class="flex gap-3">
          <span class="text-secondary">→</span>
          <span>Dynamic pricing and yield optimization</span>
        </li>
        <li class="flex gap-3">
          <span class="text-secondary">→</span>
          <span>Risk assessment and portfolio management</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- Navigation -->
  <section class="py-12 px-6 border-t border-secondary/20">
    <div class="max-w-4xl mx-auto flex justify-between">
      <a href="/CREFuture/workforce/" class="text-gray-400 hover:text-secondary transition">← Workforce</a>
      <a href="/CREFuture/tech-stack/" class="text-gray-400 hover:text-secondary transition">Tech Stack →</a>
    </div>
  </section>
</Layout>
